{
  "manifest_version": 3,
  "name": "Phishing site detector",
  "version": "1.0.2",
  "description": "Analyses the URLs visited by the user and gives a warning if any of them are potentially malicious.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://www.virustotal.com/*",
    "https://www.openphish.com/*",
    "https://openphish.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
